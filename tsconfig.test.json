{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vitest/globals", "node"],
    "baseUrl": ".",
    "paths": {
      "vscode": ["test/mocks/vscode.ts"]
    }
  },
  "include": [
    "test/**/*.ts",
    "test/**/*.tsx",
    "client/src/**/*.ts",
    "client/src/**/*.tsx"
  ],
  "exclude": ["node_modules", "client/test", "server/test", "client/dist"]
}
